# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# Replica DSNs point to the primary ports by default because the docker-compose
# replica services are standalone PostgreSQL instances (not true streaming replicas).
# In production, point these to your actual read replicas.

SHARD0_PRIMARY_DSN=postgresql://app:secret@localhost:5432/userdb
SHARD0_REPLICA_DSN=postgresql://app:secret@localhost:5432/userdb

SHARD1_PRIMARY_DSN=postgresql://app:secret@localhost:5434/userdb
SHARD1_REPLICA_DSN=postgresql://app:secret@localhost:5434/userdb

SHARD2_PRIMARY_DSN=postgresql://app:secret@localhost:5436/userdb
SHARD2_REPLICA_DSN=postgresql://app:secret@localhost:5436/userdb

SHARD3_PRIMARY_DSN=postgresql://app:secret@localhost:5438/userdb
SHARD3_REPLICA_DSN=postgresql://app:secret@localhost:5438/userdb

# Redis
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=3600
